# Server
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://nyumbalink_user:yourpassword@localhost:5432/nyumbalink_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_64_char_random_string
JWT_REFRESH_SECRET=change_me_another_64_char_random_string

# Africa's Talking (https://account.africastalking.com)
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_username
AT_SENDER_ID=NyumbaLink

# M-Pesa Daraja (https://developer.safaricom.co.ke)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=your_paybill_number
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
MPESA_CALLBACK_URL=https://api.yourdomain.co.ke/api/transactions/mpesa-callback

# Cloudinary (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Maps (https://console.cloud.google.com)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
